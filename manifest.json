{
    "manifest_version":  3,
    "name":  "BRAINPOOL Core",
    "version":  "1.0.0",
    "description":  "AI 대화 저장 및 다음 행동 추천 - F",
    "icons":  {
                  "16":  "icons/icon16.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              },
    "action":  {
                   "default_popup":  "popup/popup.html",
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "48":  "icons/icon48.png",
                                        "128":  "icons/icon128.png"
                                    }
               },
    "permissions":  [
                        "storage",
                        "tabs",
                        "notifications",
                        "alarms",
                        "scripting",
                        "activeTab"
                    ],
    "host_permissions":  [
                             "https://*.supabase.co/*",
                             "https://claude.ai/*",
                             "https://chatgpt.com/*",
                             "https://chat.openai.com/*",
                             "https://gemini.google.com/*",
                             "https://www.perplexity.ai/*",
                             "https://api.notion.com/*"
                         ],
    "content_scripts":  [
                            {
                                "matches":  [
                                                "https://claude.ai/*",
                                                "https://chatgpt.com/*",
                                                "https://chat.openai.com/*",
                                                "https://gemini.google.com/*",
                                                "https://www.perplexity.ai/*"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle",
                                "all_frames":  true
                            }
                        ],
    "background": {
                    "service_worker": "background.js",
                    "type": "module"
                    }
}
